{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-context.sh",
            "timeout": 10,
            "statusMessage": "Loading cookbook context..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/architecture-advisor.sh",
            "timeout": 5,
            "statusMessage": "Checking for relevant standards..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__ai-architecture-cookbook__.*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-mcp-guidance.sh",
            "timeout": 5,
            "statusMessage": "Adding cookbook guidance..."
          }
        ]
      }
    ]
  }
}
